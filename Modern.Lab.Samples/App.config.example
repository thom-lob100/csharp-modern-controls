<?xml version="1.0" encoding="utf-8"?>
<!-- Oracle 접속 설정 템플릿.
     이 파일을 App.config로 복사한 뒤 실제 값으로 채운다.
     App.config는 비밀번호를 포함하므로 gitignore 대상이다. -->
<configuration>
  <appSettings>
    <!-- Oracle Autonomous Database wallet 압축을 푼 폴더 (tnsnames.ora / sqlnet.ora / cwallet.sso) -->
    <add key="Oracle.WalletDirectory" value="D:\wallet\oracle" />
    <!-- tnsnames.ora의 접속 별칭 -->
    <add key="Oracle.DataSource" value="your_db_tp" />
    <add key="Oracle.UserId" value="your_user" />
    <add key="Oracle.Password" value="your_password" />
  </appSettings>
</configuration>
