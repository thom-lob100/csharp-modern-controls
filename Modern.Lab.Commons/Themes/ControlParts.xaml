<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common">

    <!-- 컨트롤 공용 파츠 사전: 여러 컨트롤 XAML에 복제되어 있던 템플릿/스타일을
         한곳에 모은다. 각 컨트롤은 Tokens.xaml 병합 뒤에 이 사전을
         SharedResourceDictionary로 병합해 사용한다.

         주의:
         - 아래 일부 스타일의 트리거는 ElementName=RootControl 바인딩을 쓴다.
           스타일이 적용되는 요소의 네임스코프에서 이름을 찾으므로, 소비하는
           컨트롤의 루트 UserControl x:Name이 반드시 "RootControl"이어야 한다.
         - 토큰 StaticResource가 이 사전 단독으로도 해석되도록 Tokens.xaml을
           먼저 병합한다 (SharedResourceDictionary는 URI 캐시라 중복 비용 없음). -->
    <ResourceDictionary.MergedDictionaries>
        <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- 드롭다운 필드 표면 + 셰브런 (ModernComboBox / ModernCheckComboBox 공용).
         IsChecked가 드롭다운 열림을 제어한다. -->
    <ControlTemplate x:Key="Parts.FieldToggleTemplate" TargetType="ToggleButton">
        <Border x:Name="FieldBorder"
                CornerRadius="{StaticResource Radius.Sm}"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1">
            <TextBlock Text="&#xE70D;"
                       FontFamily="{StaticResource Font.Family.Icon}"
                       FontSize="{StaticResource Font.Size.IconSm}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{StaticResource Brush.TextSecondary}" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="FieldBorder" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 모던 체크박스(박스 18px + 콘텐츠): 둥근 사각(4px) + 액센트 채움 + 흰 체크 글리프.
         IsChecked=null(부분 선택)은 대시 글리프로 표시 -->
    <Style x:Key="Parts.CheckBoxStyle" TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box"
                                Width="18" Height="18"
                                CornerRadius="4"
                                Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="Glyph"
                                       Text="&#xE73E;"
                                       FontFamily="{StaticResource Font.Family.Icon}"
                                       FontSize="{StaticResource Font.Size.Icon}"
                                       Foreground="{StaticResource Brush.OnAccent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                          LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- 부분 선택(전체 선택 헤더 전용) -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Glyph" Property="Text" Value="&#xE738;" />
                            <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 그리드 셀/헤더 체크박스(박스 16px 전용): Parts.CheckBoxStyle과 같은 모던
         비주얼의 박스 전용 버전 — OS 기본 체크박스 룩을 쓰지 않는다.
         헤더 전체선택의 중간 상태(일부만 체크)는 액센트 채움 + 대시 글리프로 표시한다. -->
    <Style x:Key="Parts.GridCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Box"
                            Width="16" Height="16"
                            CornerRadius="4"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="Glyph"
                                   Text="&#xE73E;"
                                   FontFamily="{StaticResource Font.Family.Icon}"
                                   FontSize="{StaticResource Font.Size.IconSm}"
                                   Foreground="{StaticResource Brush.OnAccent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Glyph" Property="Text" Value="&#xE738;" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 그리드 셀 콤보 항목 (GridColumnKind.Combo 전용) — ModernComboBox
         항목과 같은 문법의 컴팩트 버전. -->
    <Style x:Key="Parts.GridComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,4,10,4" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 그리드 셀 콤보의 필드 표면 + 셰브런 — Parts.FieldToggleTemplate과
         같은 문법이지만 배경을 TemplateBinding으로 받아, 배지형 콤보가 선택
         값의 배지 색으로 필드 전체를 칠할 수 있다 (기본은 스타일의 Surface). -->
    <ControlTemplate x:Key="Parts.GridComboToggleTemplate" TargetType="ToggleButton">
        <Border x:Name="FieldBorder"
                CornerRadius="{StaticResource Radius.Sm}"
                Background="{TemplateBinding Background}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1">
            <TextBlock Text="&#xE70D;"
                       FontFamily="{StaticResource Font.Family.Icon}"
                       FontSize="{StaticResource Font.Size.IconSm}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{StaticResource Brush.TextSecondary}" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="FieldBorder" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 그리드 셀 콤보 (GridColumnKind.Combo 전용): 24px 컴팩트 필드 —
         행 높이(32) 안에 세로 중앙으로 앉는다. 필드 배경은 ComboBox의
         Background를 따른다(기본 Surface) — 배지형 콤보는 이 값을 선택 값의
         배지 색으로 바인딩해 필드 전체가 배지처럼 칠해진다. -->
    <Style x:Key="Parts.GridComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="24" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Parts.GridComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="DropToggle"
                                      Focusable="False"
                                      ClickMode="Press"
                                      Background="{TemplateBinding Background}"
                                      Template="{StaticResource Parts.GridComboToggleTemplate}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        <ContentPresenter x:Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="10,0,26,0"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False" />
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{StaticResource Brush.Surface}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Margin="0,2,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="{StaticResource Brush.DisabledText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 둥근 필드 표면(OuterBorder) 공용 스타일: 테두리 색은 hover/포커스에
         반응하고, 배경은 비활성 상태에 반응한다. hover/포커스/비활성 판정이
         모두 루트(RootControl) 기준인 컨트롤(Numeric/Date/Month)에서 쓴다 —
         ModernTextBox는 hover 소스가 내부 에디터라 자체 스타일을 유지한다. -->
    <Style x:Key="Parts.FieldBorderStyle" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource Size.ControlHeight}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootControl}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
            </DataTrigger>
            <!-- 포커스가 hover보다 우선: 나중에 선언되어 우선순위를 가진다 -->
            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=RootControl}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsEnabled, ElementName=RootControl}" Value="False">
                <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 필수 미입력 점(RequiredDot) 공용 외형: 6×6 빨간 원, 기본 숨김.
         표시 트리거(Required + placeholder 표시)는 참조하는 형제 요소 이름이
         컨트롤마다 달라 각 컨트롤에서 BasedOn으로 덧붙인다. -->
    <Style x:Key="Parts.RequiredDotStyle" TargetType="Border">
        <Setter Property="Width" Value="6" />
        <Setter Property="Height" Value="6" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource Brush.ErrorBorder}" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Visibility" Value="Collapsed" />
    </Style>

    <!-- placeholder 안내 텍스트 공용 외형: 회색 본문 크기, 히트 테스트 제외.
         표시/숨김 로직(코드 관리 또는 Text 빈 값 트리거)은 각 컨트롤이 가진다. -->
    <Style x:Key="Parts.PlaceholderTextStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPlaceholder}" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="LayoutTransform" Value="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
    </Style>

    <!-- 카드 표면: 토큰 규칙(컨트롤 4 / 카드 8)에 따른 큰 반경.
         Flat=True이면 공용 카드 패널 위에서 쓰도록 크롬을 제거한다.
         기본 Padding은 16,10 — 다른 값이 필요한 컨트롤은 BasedOn으로 덮는다. -->
    <Style x:Key="Parts.CardSurfaceStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,10" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Flat, ElementName=RootControl}" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
