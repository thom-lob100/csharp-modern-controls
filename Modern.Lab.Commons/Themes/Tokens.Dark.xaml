<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- 다크 테마 오버라이드 — Windows 11(WinUI 3) 순정 다크 팔레트.    -->
    <!-- 창 배경 #202020(Mica 근사), 카드 #2B2B2B, 액센트는 밝은 하늘색  -->
    <!-- #4CC2FF + **검정 OnAccent** (Win11 다크 액센트 버튼 시그니처).  -->
    <!-- 간격/크기/반경/폰트 크기는 색이 아니므로 재정의하지 않는다.      -->
    <!-- SharedResourceDictionary가 ModernTheme.IsDark일 때만 병합한다.  -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — SystemAccentColorLight2 계열 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF4CC2FF" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF6ECFFF" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF3AA5DC" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FF000000" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FF1E4964" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FFB7E3FF" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF4CC2FF" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#554CC2FF" />

    <!-- Neutral (서피스 / 테두리 / 텍스트) — Win11 다크 뉴트럴 -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FF202020" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF333333" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FF2E2E2E" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FF363636" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FF303030" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF414141" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FF383838" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FF575757" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFA0A0A0" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="#FF7E7E7E" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FF323232" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#FF6E6E6E" />

    <!-- Semantic — WinUI 다크 InfoBar 계열 (#6CCB5F / #FCE100 완화 / #FF99A4) -->
    <SolidColorBrush x:Key="Brush.InfoBackground" Color="#FF1F3A54" />
    <SolidColorBrush x:Key="Brush.InfoBorder" Color="#FF2F5578" />
    <SolidColorBrush x:Key="Brush.InfoText" Color="#FF79C2FF" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF6CCB5F" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="#FF7FD573" />
    <SolidColorBrush x:Key="Brush.SuccessPressed" Color="#FF54B247" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FF393D1B" />
    <SolidColorBrush x:Key="Brush.SuccessBorder" Color="#FF515A28" />
    <SolidColorBrush x:Key="Brush.SuccessText" Color="#FF6CCB5F" />
    <!-- Excel 내보내기 버튼(ButtonKind.Excel) — 어두운 배경 위 밝은 초록
         아웃라인 (hover 채움은 어두운 초록 면). -->
    <SolidColorBrush x:Key="Brush.ExcelText" Color="#FF52C08A" />
    <SolidColorBrush x:Key="Brush.ExcelBorderSoft" Color="#FF2F5C46" />
    <SolidColorBrush x:Key="Brush.ExcelBackground" Color="#FF1E3A2C" />
    <SolidColorBrush x:Key="Brush.ExcelBorder" Color="#FF3F7F5D" />
    <SolidColorBrush x:Key="Brush.ExcelPressed" Color="#FF7FDBAC" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFE8B33D" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FF433519" />
    <SolidColorBrush x:Key="Brush.WarningBorder" Color="#FF6B5527" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="#FFE8B33D" />
    <SolidColorBrush x:Key="Brush.StatusSuccess" Color="#FF6CCB5F" />
    <SolidColorBrush x:Key="Brush.StatusWarning" Color="#FFE8B33D" />
    <SolidColorBrush x:Key="Brush.ErrorBorder" Color="#FFFF7A85" />
    <SolidColorBrush x:Key="Brush.ErrorBorderSoft" Color="#FF6B3A3E" />
    <SolidColorBrush x:Key="Brush.ErrorBackground" Color="#FF442726" />
    <SolidColorBrush x:Key="Brush.ErrorText" Color="#FFFF99A4" />
    <SolidColorBrush x:Key="Brush.DangerPressed" Color="#FFD13F4C" />
    <SolidColorBrush x:Key="Brush.NeutralBackground" Color="#FF383838" />
    <SolidColorBrush x:Key="Brush.NeutralText" Color="#FFD0D0D0" />

    <SolidColorBrush x:Key="Brush.Scrim" Color="#99000000" />

    <Color x:Key="Color.Accent">#FF4CC2FF</Color>
    <Color x:Key="Color.AccentSoft">#FF9ADCFF</Color>
    <Color x:Key="Color.TrackOff">#FF5C5C5C</Color>

    <!-- Text.* 스타일도 재정의해야 한다 — 이 스타일은 Tokens.xaml 안에서 라이트 브러시를
         StaticResource로 이미 확정했으므로, 브러시만 덮어써서는 글자색이 바뀌지 않는다.
         여기서 다크 전경으로 다시 정의하면 병합 우선순위상 이쪽이 이긴다. -->
    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Label}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Helper" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Helper}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
