<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- 다크 테마 오버라이드 — Tokens.xaml 뒤에 병합되어 같은 Brush.*/  -->
    <!-- Text.* 키를 어두운 값으로 덮어쓴다. 간격/크기/반경/폰트 크기는   -->
    <!-- 색이 아니므로 재정의하지 않는다(라이트와 공유).                  -->
    <!-- SharedResourceDictionary가 ModernTheme.IsDark일 때만 병합한다.  -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 어두운 배경에서 읽히도록 밝은 블루로 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF3B9EFF" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF60AFFF" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF1B7FE0" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FF163A5E" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FFCFE8FF" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF3B9EFF" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#553B9EFF" />

    <!-- Neutral (서피스 / 테두리 / 텍스트) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF2A2A2B" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF323233" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FF2D2D2E" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FF31383F" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FF313132" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF3F3F46" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FF3A3A3C" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FF5A5A62" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFE6E6E6" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="#FF7A7F87" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FF333336" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#FF2A2A2B" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#FF6B7280" />

    <!-- Semantic — 어두운 면에 맞춘 배경/테두리/텍스트 -->
    <SolidColorBrush x:Key="Brush.InfoBackground" Color="#FF12283F" />
    <SolidColorBrush x:Key="Brush.InfoBorder" Color="#FF244A73" />
    <SolidColorBrush x:Key="Brush.InfoText" Color="#FF7FB4F0" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF3FB950" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="#FF35A144" />
    <SolidColorBrush x:Key="Brush.SuccessPressed" Color="#FF2C8639" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FF122117" />
    <SolidColorBrush x:Key="Brush.SuccessBorder" Color="#FF2A4A34" />
    <SolidColorBrush x:Key="Brush.SuccessText" Color="#FF56D364" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFE0A030" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FF2A2412" />
    <SolidColorBrush x:Key="Brush.WarningBorder" Color="#FF5A4A1E" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="#FFE0B84D" />
    <SolidColorBrush x:Key="Brush.StatusSuccess" Color="#FF3FB950" />
    <SolidColorBrush x:Key="Brush.StatusWarning" Color="#FFE0A030" />
    <SolidColorBrush x:Key="Brush.ErrorBorder" Color="#FFF04747" />
    <SolidColorBrush x:Key="Brush.ErrorBorderSoft" Color="#FF5A2A2A" />
    <SolidColorBrush x:Key="Brush.ErrorBackground" Color="#FF2A1414" />
    <SolidColorBrush x:Key="Brush.ErrorText" Color="#FFF07070" />
    <SolidColorBrush x:Key="Brush.DangerPressed" Color="#FFC03030" />
    <SolidColorBrush x:Key="Brush.NeutralBackground" Color="#FF3A3A3C" />
    <SolidColorBrush x:Key="Brush.NeutralText" Color="#FFD1D5DB" />

    <SolidColorBrush x:Key="Brush.Scrim" Color="#99000000" />

    <Color x:Key="Color.Accent">#FF3B9EFF</Color>
    <Color x:Key="Color.TrackOff">#FF5A5A62</Color>

    <!-- Text.* 스타일도 재정의해야 한다 — 이 스타일은 Tokens.xaml 안에서 라이트 브러시를
         StaticResource로 이미 확정했으므로, 브러시만 덮어써서는 글자색이 바뀌지 않는다.
         여기서 다크 전경으로 다시 정의하면 병합 우선순위상 이쪽이 이긴다. -->
    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Label}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Helper" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Helper}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
