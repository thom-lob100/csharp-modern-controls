<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Gray 테마 오버라이드 — 라이트 기반 무채색(슬레이트) 틴트.        -->
    <!-- Tokens.xaml 뒤에 병합되어 액센트 계열과 배경 톤만 덮어쓴다.      -->
    <!-- 텍스트/시맨틱(성공·경고·오류) 색은 라이트 값을 그대로 공유한다.  -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Gray일 때 병합.  -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 슬레이트 그레이 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF64748B" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF78849A" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF475569" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFE2E8F0" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF334155" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF64748B" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#5564748B" />

    <!-- Neutral — 쿨 그레이 배경 톤 (표면은 라이트와 같은 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFE7EAEE" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF1F3F6" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF1F3F6" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFE2E6EB" />

    <Color x:Key="Color.Accent">#FF64748B</Color>

</ResourceDictionary>
