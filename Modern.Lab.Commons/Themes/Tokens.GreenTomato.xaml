<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- GreenTomato 테마 오버라이드 — 딥 그린(#217346) 액센트 +          -->
    <!-- 민트 파스텔 뉴트럴, 선택 강조는 토마토 파스텔. 흰 카드 유지.     -->
    <!-- 텍스트/시맨틱 색은 Win11 순정 값으로 아래에서 명시적으로 고정한다. -->
    <!-- SharedResourceDictionary가 Mode == GreenTomato일 때 병합.       -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 딥 그린 #217346 램프 (Green 담당) -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF217346" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF2B8A57" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF195C38" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <!-- 선택 강조는 토마토 파스텔이 담당 — 그린 화면 위에서 확실히 구분된다. -->
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFF8D8D2" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF8C2B1E" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF217346" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#33217346" />

    <!-- Neutral — 민트 파스텔 배경·테두리 (카드 표면 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFE8F4EB" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF3FAF5" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF3FAF5" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFD5EBDD" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFF2F9F4" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFBFDFCB" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFD8ECDF" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FF85C29D" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFEDF7F0" />

    <Color x:Key="Color.Accent">#FF217346</Color>
    <Color x:Key="Color.AccentSoft">#FF63B784</Color>

    <!-- 텍스트/시맨틱 — Win11 순정 값으로 고정. 라이트 기본 팔레트가 이전의
         연한 톤으로 되돌아가면서, 상속에 기대면 이 테마까지 함께 바뀌므로
         여기서 명시적으로 덮는다. -->
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF1B1B1B" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF5D5D5D" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="#FF9B9B9B" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#FF9D9D9D" />
    <SolidColorBrush x:Key="Brush.InfoBackground" Color="#FFEBF3FC" />
    <SolidColorBrush x:Key="Brush.InfoBorder" Color="#FFBBD7F0" />
    <SolidColorBrush x:Key="Brush.InfoText" Color="#FF005FB8" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF0F7B0F" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="#FF0C660C" />
    <SolidColorBrush x:Key="Brush.SuccessPressed" Color="#FF094F09" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FFDFF6DD" />
    <SolidColorBrush x:Key="Brush.SuccessBorder" Color="#FFA9D8A4" />
    <SolidColorBrush x:Key="Brush.SuccessText" Color="#FF0F7B0F" />
    <!-- Excel 내보내기 버튼(ButtonKind.Excel) — 초록 액센트 테마와 겹치지
         않게 틸 쪽으로 기울인 초록 아웃라인. -->
    <SolidColorBrush x:Key="Brush.ExcelText" Color="#FF116149" />
    <SolidColorBrush x:Key="Brush.ExcelBorderSoft" Color="#FF9AD1BE" />
    <SolidColorBrush x:Key="Brush.ExcelBackground" Color="#FFE2F4ED" />
    <SolidColorBrush x:Key="Brush.ExcelBorder" Color="#FF5FB694" />
    <SolidColorBrush x:Key="Brush.ExcelPressed" Color="#FF0C4735" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FF9D5D00" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FFFFF4CE" />
    <SolidColorBrush x:Key="Brush.WarningBorder" Color="#FFEDD88F" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="#FF9D5D00" />
    <SolidColorBrush x:Key="Brush.StatusSuccess" Color="#FF0F7B0F" />
    <SolidColorBrush x:Key="Brush.StatusWarning" Color="#FF9D5D00" />
    <SolidColorBrush x:Key="Brush.ErrorBorder" Color="#FFC42B1C" />
    <SolidColorBrush x:Key="Brush.ErrorBorderSoft" Color="#FFF2B8B2" />
    <SolidColorBrush x:Key="Brush.ErrorBackground" Color="#FFFDE7E9" />
    <SolidColorBrush x:Key="Brush.ErrorText" Color="#FFC42B1C" />
    <SolidColorBrush x:Key="Brush.DangerPressed" Color="#FFA4262C" />
    <SolidColorBrush x:Key="Brush.NeutralBackground" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="Brush.NeutralText" Color="#FF3B3B3B" />

    <Color x:Key="Color.TrackOff">#FFC8C8C8</Color>

</ResourceDictionary>
