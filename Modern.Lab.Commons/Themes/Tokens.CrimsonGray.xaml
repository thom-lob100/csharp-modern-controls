<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- CrimsonGray 테마 오버라이드 — 연한 미드 그레이 모노톤(#555555     -->
    <!-- 기반, Gray 담당) 위에 라이트 크림슨 액센트(Crimson 담당).        -->
    <!-- 뉴트럴/시맨틱은 미드 그레이 면 기준을 유지한다.                  -->
    <!-- SharedResourceDictionary가 Mode == CrimsonGray일 때 병합.       -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 라이트 크림슨 (미드 그레이 면에서 또렷하고,
         OnAccent는 딥 크림슨-블랙으로 채움 버튼 가독성 확보) -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFF2919E" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFF6A7B2" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFE4707F" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FF38121A" />
    <!-- 선택 강조는 크림슨 틴트 그레이 — 모노톤 화면에서 은은하게 붉다. -->
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FF855A62" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FFFFEDEF" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FFF2919E" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#55F2919E" />

    <!-- Neutral (서피스 / 테두리 / 텍스트) — 연한 미드 그레이 -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FF555555" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF616161" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF686868" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FF656565" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FF6E6E6E" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FF666666" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF7A7A7A" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FF707070" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FF929292" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFCCCCCC" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="#FFB0B0B0" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FF6B6B6B" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#FF616161" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#FF9C9C9C" />

    <!-- Semantic — 미드 그레이 면에 맞춘 채도 (다크보다 밝은 면색) -->
    <SolidColorBrush x:Key="Brush.InfoBackground" Color="#FF41505F" />
    <SolidColorBrush x:Key="Brush.InfoBorder" Color="#FF56697C" />
    <SolidColorBrush x:Key="Brush.InfoText" Color="#FFAFD3F2" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF7ED672" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="#FF90DE85" />
    <SolidColorBrush x:Key="Brush.SuccessPressed" Color="#FF63BD57" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FF4E5834" />
    <SolidColorBrush x:Key="Brush.SuccessBorder" Color="#FF66743F" />
    <SolidColorBrush x:Key="Brush.SuccessText" Color="#FF9FE295" />
    <!-- Excel 내보내기 버튼(ButtonKind.Excel) — 어두운 배경 위 밝은 초록
         아웃라인 (hover 채움은 어두운 초록 면). -->
    <SolidColorBrush x:Key="Brush.ExcelText" Color="#FF74CDA0" />
    <SolidColorBrush x:Key="Brush.ExcelBorderSoft" Color="#FF3C5F4D" />
    <SolidColorBrush x:Key="Brush.ExcelBackground" Color="#FF263C31" />
    <SolidColorBrush x:Key="Brush.ExcelBorder" Color="#FF528568" />
    <SolidColorBrush x:Key="Brush.ExcelPressed" Color="#FF95E0BB" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFEDBD53" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FF5C4E2C" />
    <SolidColorBrush x:Key="Brush.WarningBorder" Color="#FF7C693B" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="#FFF0C978" />
    <SolidColorBrush x:Key="Brush.StatusSuccess" Color="#FF7ED672" />
    <SolidColorBrush x:Key="Brush.StatusWarning" Color="#FFEDBD53" />
    <SolidColorBrush x:Key="Brush.ErrorBorder" Color="#FFFF97A0" />
    <SolidColorBrush x:Key="Brush.ErrorBorderSoft" Color="#FF80545A" />
    <SolidColorBrush x:Key="Brush.ErrorBackground" Color="#FF5E4144" />
    <SolidColorBrush x:Key="Brush.ErrorText" Color="#FFFFB2B9" />
    <SolidColorBrush x:Key="Brush.DangerPressed" Color="#FFDE6570" />
    <SolidColorBrush x:Key="Brush.NeutralBackground" Color="#FF707070" />
    <SolidColorBrush x:Key="Brush.NeutralText" Color="#FFDEDCDA" />

    <SolidColorBrush x:Key="Brush.Scrim" Color="#99000000" />

    <Color x:Key="Color.Accent">#FFF2919E</Color>
    <Color x:Key="Color.AccentSoft">#FFF8C1C9</Color>
    <Color x:Key="Color.TrackOff">#FF929292</Color>

    <!-- Text.* 스타일 재정의 — 어두운 전경 (Dark와 동일 이유) -->
    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Label}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Helper" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Helper}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
