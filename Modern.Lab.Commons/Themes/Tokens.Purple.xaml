<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Purple 테마 오버라이드 — 라벤더 파스텔 (라이트 기반).            -->
    <!-- 흰 카드가 뚜렷한 파스텔 배경/테두리 위에 떠 보이도록 배경·테두리· -->
    <!-- 선택 강조를 틴트한다. 텍스트/시맨틱 색은 라이트 값을 공유한다.   -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Purple일 때 병합. -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 바이올렛 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF7C3AED" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF8B5CF6" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF6D28D9" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFDDCFF7" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF5B21B6" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF7C3AED" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#557C3AED" />

    <!-- Neutral — 라벤더 파스텔 배경·테두리 (카드 표면은 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFEAE3F8" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF3EEFB" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF3EEFB" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFE3D9F5" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFF6F3FC" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD8CCF0" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFE4DCF4" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FFB9A5E3" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFF0EAFA" />

    <Color x:Key="Color.Accent">#FF7C3AED</Color>

</ResourceDictionary>
