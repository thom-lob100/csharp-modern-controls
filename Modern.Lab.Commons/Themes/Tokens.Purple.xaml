<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Purple 테마 오버라이드 — 라이트 기반 바이올렛 틴트.              -->
    <!-- Tokens.xaml 뒤에 병합되어 액센트 계열과 배경 톤만 덮어쓴다.      -->
    <!-- 텍스트/시맨틱(성공·경고·오류) 색은 라이트 값을 그대로 공유한다.  -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Purple일 때 병합. -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 바이올렛 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF7C3AED" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF8B5CF6" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF6D28D9" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFEDE9FE" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF5B21B6" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF7C3AED" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#557C3AED" />

    <!-- Neutral — 라벤더 배경 톤 (표면은 라이트와 같은 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF5F3FA" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF8F6FC" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF8F6FC" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFEEE9F8" />

    <Color x:Key="Color.Accent">#FF7C3AED</Color>

</ResourceDictionary>
