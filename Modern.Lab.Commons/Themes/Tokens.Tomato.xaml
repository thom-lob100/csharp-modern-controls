<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Tomato 테마 오버라이드 — 로즈 파스텔 (라이트 기반).              -->
    <!-- 흰 카드가 뚜렷한 파스텔 배경/테두리 위에 떠 보이도록 배경·테두리· -->
    <!-- 선택 강조를 틴트한다. 텍스트/시맨틱 색은 라이트 값을 공유한다.   -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Tomato일 때 병합. -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — 토마토 (흰 글자 대비를 위해 순수 tomato보다 짙게) -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFD9442B" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFEB5B41" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFB93A24" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFFCD6CC" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF9A2F1C" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FFD9442B" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#55D9442B" />

    <!-- Neutral — 로즈 파스텔 배경·테두리 (카드 표면은 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFFBE3DD" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFFDF0EC" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFFDF0EC" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFF8DCD4" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFFDF3F0" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFF2CFC6" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFF8DED7" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FFE5A99A" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFFCEEEA" />

    <Color x:Key="Color.Accent">#FFD9442B</Color>

</ResourceDictionary>
