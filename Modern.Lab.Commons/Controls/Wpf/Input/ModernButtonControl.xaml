<UserControl x:Class="Modern.Lab.Controls.Wpf.Input.ModernButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="120" d:DesignHeight="40">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared button style: rounded corners, centered content, hover/pressed
                 color feedback. Per-kind (Primary/Secondary/Danger) colors are
                 switched by the DataTriggers below. -->
            <Style x:Key="ModernButtonStyle" TargetType="Button">
                <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="{StaticResource Size.ControlHeight}" />
                <Setter Property="Padding" Value="{StaticResource Pad.Button}" />
                <Setter Property="Cursor" Value="Hand" />
                <!-- Defaults (Primary): accent background, white text -->
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.OnAccent}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Secondary: white background, gray border, dark text -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                    </DataTrigger>
                    <!-- Danger: outlined red — red text on white with a soft red border.
                         Kept quiet at rest; the red only intensifies on interaction. -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Danger">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.ErrorText}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.ErrorBorderSoft}" />
                    </DataTrigger>
                    <!-- Subtle: borderless text button for low-emphasis actions -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Subtle">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </DataTrigger>
                    <!-- Execute: success-green fill for the important execute action -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Execute">
                        <Setter Property="Background" Value="{StaticResource Brush.Success}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.OnAccent}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Success}" />
                    </DataTrigger>

                    <!-- Primary: hover = darker blue, pressed = darkest blue -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Primary" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.AccentHover}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Primary" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.AccentPressed}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentPressed}" />
                    </MultiDataTrigger>

                    <!-- Secondary: hover = light blue tint with accent border/text,
                         pressed = slightly deeper blue tint -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.InfoBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.AccentHover}" />
                    </MultiDataTrigger>

                    <!-- Danger: hover = pale red fill with strong border, pressed = deeper -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Danger" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.ErrorBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.ErrorBorder}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Danger" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.ErrorBorderSoft}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.DangerPressed}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.DangerPressed}" />
                    </MultiDataTrigger>

                    <!-- Subtle: hover = neutral fill, pressed = slightly deeper -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Subtle" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Subtle" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.BorderSubtle}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                    </MultiDataTrigger>

                    <!-- Execute: hover/pressed = deeper greens -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Execute" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.SuccessHover}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.SuccessHover}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Execute" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.SuccessPressed}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.SuccessPressed}" />
                    </MultiDataTrigger>

                    <!-- Disabled: uniform gray regardless of kind. Placed last so it
                         overrides the kind triggers above. -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- The actual button: optional icon + display text; Click is re-exposed. -->
    <Button x:Name="InnerButton"
            Style="{StaticResource ModernButtonStyle}"
            Click="InnerButton_Click">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       FontSize="{StaticResource Font.Size.Body}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{Binding IconGlyph, ElementName=RootControl}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IconGlyph, ElementName=RootControl}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding Text, ElementName=RootControl}" VerticalAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>
