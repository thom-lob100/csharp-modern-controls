<UserControl x:Class="Modern.Lab.Controls.Wpf.Input.ModernTextBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="200" d:DesignHeight="32">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Rounded field surface. Border color reacts to hover/focus; background
         reacts to read-only/disabled. Colors are set only via style setters so
         the triggers below can override them. -->
    <Border x:Name="OuterBorder"
            Height="{StaticResource Size.ControlHeight}"
            CornerRadius="{StaticResource Radius.Sm}"
            BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=InnerTextBox}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                    </DataTrigger>
                    <!-- Focus wins over hover: declared later so it takes precedence -->
                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=RootControl}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsReadOnly, ElementName=RootControl}" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsEnabled, ElementName=RootControl}" Value="False">
                        <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- Placeholder: visible only while the text is empty; never hit-testable -->
            <TextBlock x:Name="PlaceholderText"
                       Text="{Binding Placeholder, ElementName=RootControl}"
                       Margin="{StaticResource Pad.Field}"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Body}"
                       Foreground="{StaticResource Brush.TextPlaceholder}"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=RootControl}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text, ElementName=RootControl}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- The actual editor: borderless, transparent, centered vertically -->
            <TextBox x:Name="InnerTextBox"
                     Text="{Binding Text, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="{StaticResource Pad.Field}"
                     VerticalContentAlignment="Center"
                     FontSize="{StaticResource Font.Size.Body}"
                     Foreground="{StaticResource Brush.TextPrimary}"
                     KeyDown="InnerTextBox_KeyDown" />
        </Grid>
    </Border>
</UserControl>
