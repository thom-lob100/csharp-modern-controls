<UserControl x:Class="Modern.Lab.Controls.Wpf.Input.ModernTextBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="200" d:DesignHeight="32">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 둥근 필드 표면. 테두리 색은 hover/포커스에 반응하고, 배경은
         읽기 전용/비활성 상태에 반응한다. 색상은 아래 트리거가 덮어쓸 수 있도록
         스타일 setter로만 지정한다. -->
    <Border x:Name="OuterBorder"
            Height="{StaticResource Size.ControlHeight}"
            CornerRadius="{StaticResource Radius.Sm}"
            BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=InnerTextBox}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                    </DataTrigger>
                    <!-- 포커스가 hover보다 우선: 나중에 선언되어 우선순위를 가진다 -->
                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=RootControl}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsReadOnly, ElementName=RootControl}" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsEnabled, ElementName=RootControl}" Value="False">
                        <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- Placeholder: 에디터가 비어 있는 동안에만 표시. 표시 여부는 내부
                 TextBox.TextChanged에서 코드로 관리하는데, 이 이벤트는 IME 조합
                 중에도 발생한다 — 바인딩 기반 트리거였다면 첫 한글 음절이 확정될
                 때까지 계속 보였을 것이다 (WPF는 조합이 진행 중인 동안 바인딩
                 소스 업데이트를 미룬다). -->
            <TextBlock x:Name="PlaceholderText"
                       Text="{Binding Placeholder, ElementName=RootControl}"
                       Margin="{StaticResource Pad.Field}"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Body}"
                       Foreground="{StaticResource Brush.TextPlaceholder}"
                       IsHitTestVisible="False" />

            <!-- 실제 에디터: 테두리 없음, 투명 배경, 세로 중앙 정렬 -->
            <TextBox x:Name="InnerTextBox"
                     Text="{Binding Text, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="{StaticResource Pad.Field}"
                     VerticalContentAlignment="Center"
                     FontSize="{StaticResource Font.Size.Body}"
                     Foreground="{StaticResource Brush.TextPrimary}"
                     KeyDown="InnerTextBox_KeyDown"
                     PreviewKeyDown="InnerTextBox_PreviewKeyDown"
                     TextChanged="InnerTextBox_TextChanged"
                     LostKeyboardFocus="InnerTextBox_LostKeyboardFocus" />

            <!-- 필수 미입력 점: Required이면서 값이 비어 있는 동안만 오른쪽에 표시.
                 빈 값 판정은 IME까지 고려하는 placeholder 표시 로직을 그대로 따른다. -->
            <Border x:Name="RequiredDot"
                    Width="6"
                    Height="6"
                    CornerRadius="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    Background="{StaticResource Brush.ErrorBorder}"
                    IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Required, ElementName=RootControl}" Value="True" />
                                    <Condition Binding="{Binding Visibility, ElementName=PlaceholderText}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- 자동완성 드롭다운(검색창 스타일). 항목이 포커스를 받지 않으므로
                 탐색 중에도 키보드 포커스는 에디터에 남는다. -->
            <Popup x:Name="SuggestionPopup"
                   PlacementTarget="{Binding ElementName=OuterBorder}"
                   Placement="Bottom"
                   AllowsTransparency="True"
                   Focusable="False"
                   StaysOpen="True"
                   PopupAnimation="Slide">
                <Border Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Margin="0,2,0,0"
                        MinWidth="{Binding ActualWidth, ElementName=OuterBorder}"
                        MaxHeight="240">
                    <ListBox x:Name="SuggestionList"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Padding" Value="{StaticResource Pad.Item}" />
                                <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SuggestionItem_MouseDown" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
