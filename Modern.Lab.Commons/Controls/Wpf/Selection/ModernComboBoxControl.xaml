<UserControl x:Class="Modern.Lab.Controls.Wpf.Selection.ModernComboBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="200" d:DesignHeight="32">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/ControlParts.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- 드롭다운 항목: hover/선택 상태는 토큰에서 가져온다 -->
            <Style x:Key="ModernComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Padding" Value="{StaticResource Pad.Item}" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- 토큰 스타일 템플릿이 적용된 실제 ComboBox. ItemsSource는 코드에서
             할당된다(내부적으로 필터링된 컬렉션). 이렇게 해야 편집 가능 모드가
             입력 중에 필터링할 수 있다. -->
        <ComboBox x:Name="InnerComboBox"
                  Height="{StaticResource Size.ControlHeight}"
                  FontSize="{StaticResource Font.Size.Body}"
                  Foreground="{StaticResource Brush.TextPrimary}"
                  ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"
                  IsEditable="{Binding IsEditable, ElementName=RootControl}"
                  IsTextSearchEnabled="False"
                  DisplayMemberPath="{Binding DisplayMemberPath, ElementName=RootControl}"
                  SelectedValuePath="{Binding SelectedValuePath, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  SelectedValue="{Binding SelectedValue, ElementName=RootControl, Mode=TwoWay}"
                  SelectionChanged="InnerComboBox_SelectionChanged"
                  Loaded="InnerComboBox_Loaded">
            <ComboBox.Template>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- 필드 표면 + 셰브런은 공용 파츠(Parts.FieldToggleTemplate)를 쓴다 -->
                        <ToggleButton x:Name="DropToggle"
                                      Focusable="False"
                                      ClickMode="Press"
                                      Template="{StaticResource Parts.FieldToggleTemplate}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        <!-- 선택 항목 표시 (히트 테스트 대상 아님; 클릭은 토글이 처리) -->
                        <ContentPresenter x:Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="12,0,32,0"
                                          VerticalAlignment="Center"
                                          LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}"
                                          IsHitTestVisible="False" />
                        <!-- 멀티컬럼 모드의 선택 텍스트: 항목 템플릿이 멀티컬럼 행이라
                             필드에는 대신 TextSearch 기반 Text(표시 명칭)를 보여준다.
                             표시 여부는 코드에서 관리. -->
                        <TextBlock x:Name="MultiColumnSelectionText"
                                   Text="{TemplateBinding Text}"
                                   Margin="12,0,32,0"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"
                                   LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}"
                                   IsHitTestVisible="False" />
                        <!-- 편집 가능 텍스트 영역(검색형 콤보). IsEditable일 때
                             ContentSite 대신 표시된다; 오른쪽 32px는 셰브런 토글
                             몫으로 남긴다. -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Visibility="Collapsed"
                                 Style="{x:Null}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Margin="12,0,32,0"
                                 Padding="0"
                                 VerticalAlignment="Center"
                                 LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}"
                                 VerticalContentAlignment="Center"
                                 FontSize="{StaticResource Font.Size.Body}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{StaticResource Brush.Surface}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Margin="0,2,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <DockPanel>
                                    <!-- 멀티컬럼 헤더 행 호스트: 컬럼이 구성되면
                                         코드에서 내용이 채워지고 표시된다 -->
                                    <Border x:Name="DropDownHeaderHost"
                                            DockPanel.Dock="Top"
                                            Visibility="Collapsed"
                                            Background="{StaticResource Brush.GridHeaderBackground}"
                                            BorderBrush="{StaticResource Brush.BorderSubtle}"
                                            BorderThickness="0,0,0,1" />
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="{StaticResource Brush.DisabledText}" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ComboBox.Template>
        </ComboBox>

        <!-- 아무것도 선택/입력되지 않은 동안의 placeholder 오버레이.
             표시 여부는 코드에서 관리한다(선택, 입력 텍스트, IME 조합이
             모두 영향을 준다). -->
        <TextBlock x:Name="PlaceholderOverlay"
                   Style="{StaticResource Parts.PlaceholderTextStyle}"
                   Text="{Binding Placeholder, ElementName=RootControl}"
                   Margin="13,0,32,0" />

        <!-- 필수 미입력 점: Required이면서 값이 비어 있는 동안만 셰브런 왼쪽에 표시.
             빈 값 판정은 placeholder 표시 로직(선택·입력·IME 반영)을 그대로 따른다. -->
        <Border x:Name="RequiredDot"
                Margin="0,0,30,0">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource Parts.RequiredDotStyle}">
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Required, ElementName=RootControl}" Value="True" />
                                <Condition Binding="{Binding Visibility, ElementName=PlaceholderOverlay}" Value="Visible" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- 강조(Highlight) 오버레이: 이 필드에 주목이 필요할 때 액센트색
             테두리 + 은은한 액센트 틴트(8%)를 덧그린다 — 핵심 선택 필드
             (예: 캐리어 배정)를 다른 필드보다 도드라지게 하는 용도다.
             틴트는 반투명이라 아래 텍스트/셰브런 가독성을 해치지 않고,
             히트 테스트도 막지 않는다. -->
        <Border Height="{StaticResource Size.ControlHeight}"
                VerticalAlignment="Center"
                BorderBrush="{StaticResource Brush.Accent}"
                BorderThickness="1.5"
                CornerRadius="{StaticResource Radius.Sm}"
                IsHitTestVisible="False"
                Visibility="{Binding Highlight, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}">
            <Border.Background>
                <SolidColorBrush Color="{Binding Color, Source={StaticResource Brush.Accent}}"
                                 Opacity="0.08" />
            </Border.Background>
        </Border>
    </Grid>
</UserControl>
