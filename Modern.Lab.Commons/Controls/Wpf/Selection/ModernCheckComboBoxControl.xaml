<UserControl x:Class="Modern.Lab.Controls.Wpf.Selection.ModernCheckComboBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="200" d:DesignHeight="32">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 필드 표면 + 화살표. ModernComboBox와 동일한 외형 -->
            <ControlTemplate x:Key="CheckComboToggleTemplate" TargetType="ToggleButton">
                <Border x:Name="FieldBorder"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1">
                    <TextBlock Text="&#xE70D;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="{StaticResource Font.Size.IconSm}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="{StaticResource Brush.TextSecondary}" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="FieldBorder" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- 모던 체크박스: 둥근 사각(4px) + 액센트 채움 + 흰 체크 글리프.
                 IsChecked=null(부분 선택)은 대시 글리프로 표시 -->
            <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <Border x:Name="Box"
                                        Width="18" Height="18"
                                        CornerRadius="4"
                                        Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="Glyph"
                                               Text="&#xE73E;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{StaticResource Font.Size.Icon}"
                                               Foreground="{StaticResource Brush.OnAccent}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <!-- 부분 선택(전체 선택 헤더 전용) -->
                                <Trigger Property="IsChecked" Value="{x:Null}">
                                    <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="Glyph" Property="Text" Value="&#xE738;" />
                                    <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 온/오프 토글 스위치: 알약형 트랙 + 원형 썸.
                 켬 = 액센트 트랙 + 오른쪽 썸, 끔 = 회색 트랙 + 왼쪽 썸 -->
            <Style x:Key="ModernSwitchStyle" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <Border x:Name="Track"
                                        Width="34" Height="18"
                                        CornerRadius="9"
                                        Background="{StaticResource Brush.Border}"
                                        VerticalAlignment="Center">
                                    <Ellipse x:Name="Thumb"
                                             Width="12" Height="12"
                                             Fill="{StaticResource Brush.OnAccent}"
                                             HorizontalAlignment="Left"
                                             Margin="3,0,3,0" />
                                </Border>
                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.BorderHover}" />
                                </Trigger>
                                <!-- 켬 상태가 hover보다 우선하도록 뒤에 선언 -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 항목 템플릿 두 종류 — ItemStyle 속성에 따라 코드에서 선택 -->
            <DataTemplate x:Key="CheckBoxItemTemplate">
                <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
                          Content="{Binding DisplayText}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Margin="12,6" />
            </DataTemplate>
            <DataTemplate x:Key="SwitchItemTemplate">
                <CheckBox Style="{StaticResource ModernSwitchStyle}"
                          Content="{Binding DisplayText}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Margin="12,6" />
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- 필드 표면; 토글 체크가 팝업 열림과 양방향 연결.
             ClickMode=Release: Press면 마우스 다운에 팝업이 열리고 이어지는
             마우스 업이 팝업 밖 입력으로 처리되어 즉시 닫힌다(StaysOpen=False
             캡처 동작). -->
        <ToggleButton x:Name="DropToggle"
                      Height="{StaticResource Size.ControlHeight}"
                      Focusable="False"
                      ClickMode="Release"
                      Template="{StaticResource CheckComboToggleTemplate}"
                      PreviewMouseLeftButtonDown="DropToggle_PreviewMouseLeftButtonDown" />

        <!-- 체크된 항목들의 표시 텍스트를 ", "로 연결해 표시 -->
        <TextBlock x:Name="DisplayText"
                   Margin="12,0,32,0"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource Font.Size.Body}"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   TextTrimming="CharacterEllipsis"
                   IsHitTestVisible="False" />

        <!-- 체크된 항목이 없을 때의 플레이스홀더 -->
        <TextBlock x:Name="PlaceholderOverlay"
                   Text="{Binding Placeholder, ElementName=RootControl}"
                   Margin="13,0,32,0"
                   VerticalAlignment="Center"
                   FontSize="{StaticResource Font.Size.Body}"
                   Foreground="{StaticResource Brush.TextPlaceholder}"
                   IsHitTestVisible="False" />

        <!-- 필수 미입력 점: Required이면서 체크된 항목이 없는 동안만 셰브런 왼쪽에 표시.
             빈 값 판정은 placeholder 표시 로직(UpdateDisplay)을 그대로 따른다. -->
        <Border x:Name="RequiredDot"
                Width="6"
                Height="6"
                CornerRadius="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,30,0"
                Background="{StaticResource Brush.ErrorBorder}"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Required, ElementName=RootControl}" Value="True" />
                                <Condition Binding="{Binding Visibility, ElementName=PlaceholderOverlay}" Value="Visible" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <Popup x:Name="ItemsPopup"
               PlacementTarget="{Binding ElementName=DropToggle}"
               Placement="Bottom"
               AllowsTransparency="True"
               Focusable="False"
               StaysOpen="False"
               PopupAnimation="Slide"
               IsOpen="{Binding IsChecked, ElementName=DropToggle, Mode=TwoWay}"
               Closed="ItemsPopup_Closed">
            <Border Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Margin="0,2,0,0"
                    MinWidth="{Binding ActualWidth, ElementName=DropToggle}"
                    MaxHeight="280">
                <DockPanel>
                    <!-- 전체 선택 헤더: 전부 체크 = 체크, 전부 해제 = 해제,
                         일부만 체크 = 부분 선택(대시) 표시 -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{StaticResource Brush.BorderSubtle}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <CheckBox x:Name="SelectAllCheck"
                                  Style="{StaticResource ModernCheckBoxStyle}"
                                  Content="전체 선택"
                                  Click="SelectAllCheck_Click" />
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CheckItemsControl" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
