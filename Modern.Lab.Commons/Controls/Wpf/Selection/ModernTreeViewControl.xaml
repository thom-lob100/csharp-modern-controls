<UserControl x:Class="Modern.Lab.Controls.Wpf.Selection.ModernTreeViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Modern.Lab.Controls.Wpf.Selection"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="200" d:DesignHeight="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ShowGuideLines(bool) → 가이드라인 Visibility -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- 펼침 토글: 오른쪽 셰브런이 펼침 시 90도 회전해 아래를 향한다 -->
            <Style x:Key="TreeExpanderStyle" TargetType="ToggleButton">
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" Width="18" Height="18">
                                <TextBlock x:Name="Chevron"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="{StaticResource Font.Size.IconSm}"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Chevron" Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="90" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 트리 항목: hover/선택 상태는 토큰, 자식은 18px 들여쓰기 -->
            <Style x:Key="ModernTreeViewItemStyle" TargetType="TreeViewItem">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TreeViewItem">
                            <StackPanel>
                                <Border x:Name="HeaderBorder"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        Background="Transparent">
                                    <!-- 헤더가 행 전체 폭을 쓰도록 DockPanel — 데이터
                                         템플릿의 배지가 오른쪽 끝에 정렬될 수 있다.
                                         세로 여백 5px로 행 높이에 숨 쉴 공간을 준다. -->
                                    <DockPanel LastChildFill="True" Margin="4,5,4,5">
                                        <ToggleButton x:Name="Expander"
                                                      DockPanel.Dock="Left"
                                                      VerticalAlignment="Center"
                                                      Style="{StaticResource TreeExpanderStyle}"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Stretch" />
                                    </DockPanel>
                                </Border>
                                <!-- 자식 영역: ShowGuideLines가 켜지면 들여쓰기 지점에
                                     옅은 세로선을 그려 부모-자식 소속을 보여준다. -->
                                <Grid x:Name="ChildrenHost">
                                    <Rectangle Width="1"
                                               HorizontalAlignment="Left"
                                               Margin="10,2,0,2"
                                               Fill="{StaticResource Brush.BorderSubtle}"
                                               Visibility="{Binding ShowGuideLines, RelativeSource={RelativeSource AncestorType={x:Type local:ModernTreeViewControl}}, Converter={StaticResource BoolToVisibility}}" />
                                    <ItemsPresenter x:Name="ItemsHost" Margin="18,0,0,0" />
                                </Grid>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsExpanded" Value="False">
                                    <Setter TargetName="ChildrenHost" Property="Visibility" Value="Collapsed" />
                                </Trigger>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                </Trigger>
                                <Trigger SourceName="HeaderBorder" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                                <!-- 선택이 hover보다 우선하도록 뒤에 선언 -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <TreeView x:Name="InnerTreeView"
              Background="Transparent"
              BorderThickness="0"
              ItemContainerStyle="{StaticResource ModernTreeViewItemStyle}"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              VirtualizingStackPanel.IsVirtualizing="False">
        <TreeView.ItemTemplate>
            <HierarchicalDataTemplate DataType="{x:Type local:TreeNodeItem}" ItemsSource="{Binding Children}">
                <!-- [글리프] 주 텍스트 [보조 텍스트] ....... [상태 배지]
                     글리프/보조/배지는 각 멤버 경로를 지정한 경우에만 보인다. -->
                <DockPanel LastChildFill="True">
                    <!-- 상태 배지: 행 오른쪽 끝, 그리드 배지와 같은 알약 -->
                    <Border DockPanel.Dock="Right"
                            Margin="8,0,2,0"
                            Padding="6,1"
                            VerticalAlignment="Center"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Background="{Binding BadgeBackground}"
                            Visibility="{Binding BadgeVisibility}">
                        <TextBlock Text="{Binding BadgeText}"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding BadgeForeground}"
                                   LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <!-- 노드 글리프: 항목 글자색을 상속해 선택 시 함께 반전된다 -->
                        <TextBlock Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{StaticResource Font.Size.IconSm}"
                                   Margin="2,0,5,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IconVisibility}" />

                        <!-- 기본은 항목 스타일의 색을 상속하고(선택 시 SelectedText 포함),
                             ForeColorMemberPath로 지정된 노드만 자기 색을 우선한다. -->
                        <TextBlock Text="{Binding DisplayText}" Margin="2,0,4,0" VerticalAlignment="Center"
                                   LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCustomForeground}" Value="True">
                                            <Setter Property="Foreground" Value="{Binding Foreground}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 보조 텍스트: 흐린 색 고정(선택 배경 틴트 위에서도 읽힌다) -->
                        <TextBlock Text="{Binding SubText}"
                                   Margin="4,0,4,0"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   FontWeight="Normal"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Visibility="{Binding SubTextVisibility}"
                                   LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                    </StackPanel>
                </DockPanel>
            </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</UserControl>
