<UserControl x:Class="Modern.Lab.Controls.Wpf.Display.ModernKpiCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="160" d:DesignHeight="72">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 카드 표면: 토큰 규칙(컨트롤 4 / 카드 8)에 따른 큰 반경.
         Flat=True이면 공용 카드 패널 위에서 쓰도록 크롬을 제거한다. -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="16,10" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Flat, ElementName=RootControl}" Value="True">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding Title, ElementName=RootControl}"
                       Style="{StaticResource Text.Label}" />
            <TextBlock Text="{Binding Value, ElementName=RootControl}"
                       FontSize="{StaticResource Font.Size.Heading}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,2,0,0" />
        </StackPanel>
    </Border>
</UserControl>
