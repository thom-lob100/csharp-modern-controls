<UserControl x:Class="Modern.Lab.Controls.Wpf.Display.ModernToastControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="280" d:DesignHeight="44">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 토스트 카드: 종류별 색 아이콘 원 + 메시지. 표시/숨김과 위치는 래퍼가 담당 -->
    <Border Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Lg}"
            Padding="12,10">
        <StackPanel Orientation="Horizontal">
            <Border x:Name="IconCircle"
                    Width="20" Height="20"
                    CornerRadius="10"
                    VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Success">
                                <Setter Property="Background" Value="{StaticResource Brush.StatusSuccess}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Warning">
                                <Setter Property="Background" Value="{StaticResource Brush.StatusWarning}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Error">
                                <Setter Property="Background" Value="{StaticResource Brush.ErrorBorder}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="IconGlyph"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="{StaticResource Font.Size.IconSm}"
                           Foreground="{StaticResource Brush.OnAccent}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE946;" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Success">
                                    <Setter Property="Text" Value="&#xE73E;" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Warning">
                                    <Setter Property="Text" Value="&#xE7BA;" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Error">
                                    <Setter Property="Text" Value="&#xE711;" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <TextBlock Text="{Binding Message, ElementName=RootControl}"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Body}"
                       Foreground="{StaticResource Brush.TextPrimary}" />
        </StackPanel>
    </Border>
</UserControl>
