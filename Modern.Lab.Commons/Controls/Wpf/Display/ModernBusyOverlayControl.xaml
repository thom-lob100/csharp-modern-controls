<UserControl x:Class="Modern.Lab.Controls.Wpf.Display.ModernBusyOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="300" d:DesignHeight="180">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 조회/처리 중 표시하는 컴팩트 로딩 팝업.
         카드가 컨트롤 전체를 채우고, 래퍼(WinForms)가 호스트를 카드 모서리와
         같은 둥근 Region으로 클리핑한다 — ElementHost는 진짜 투명이 불가하므로
         "카드 바깥 여백" 자체를 없애 배경이 투명한 것처럼 보이게 한다.
         (그래서 배경색 정합(SetOuterBackground)도 더는 필요 없다.) -->
    <Grid x:Name="OuterGrid" Background="{StaticResource Brush.Surface}">
        <Border Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="28,22">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Fluent 2식 스피너: 트랙 링 없이 얇은(3px) 단색 액센트 아크
                     (약 100°)만 회전한다 — 굵은 트랙+그라디언트보다 가볍고
                     현대적이다. 회전축은 RenderTransformOrigin(0.5,0.5) "하나만"
                     쓴다 — CenterX/Y와 함께 쓰면 축이 더해져 궤도를 벗어난다. -->
                <Grid Width="36" Height="36" HorizontalAlignment="Center">
                    <Path Stroke="{StaticResource Brush.Accent}"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Width="36" Height="36"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="18,3">
                                    <ArcSegment Point="32.8,20.6"
                                                Size="15,15"
                                                IsLargeArc="False"
                                                SweepDirection="Clockwise" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinRotate" Angle="0" />
                        </Path.RenderTransform>
                        <!-- 회전은 IsSpinning이 true인 동안에만 돈다. Loaded 시작 +
                             Forever 반복이면 래퍼가 숨겨도(WinForms Visible=false는
                             WPF Visibility를 바꾸지 않음) 애니메이션이 영원히 돌아
                             디스패처가 계속 렌더 틱을 소모한다 — 표시/숨김을 아는
                             래퍼(Busy)가 IsSpinning으로 명시적으로 켜고 끈다. -->
                        <Path.Style>
                            <Style TargetType="Path">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSpinning, ElementName=RootControl}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="SpinStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:0.8" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SpinStoryboard" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Grid>

                <!-- 주 메시지 -->
                <TextBlock Text="{Binding Message, ElementName=RootControl}"
                           Margin="0,16,0,0"
                           HorizontalAlignment="Center"
                           FontSize="{StaticResource Font.Size.Body}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Message, ElementName=RootControl}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 보조 메시지(선택) — 비어 있으면 숨긴다. -->
                <TextBlock Text="{Binding SubMessage, ElementName=RootControl}"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"
                           FontSize="{StaticResource Font.Size.Helper}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SubMessage, ElementName=RootControl}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
