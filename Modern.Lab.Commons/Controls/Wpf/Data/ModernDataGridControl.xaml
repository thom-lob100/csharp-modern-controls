<UserControl x:Class="Modern.Lab.Controls.Wpf.Data.ModernDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="480" d:DesignHeight="240">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Column header: SemiBold caption, subtle divider, sort chevron.
                 PART_RightHeaderGripper keeps mouse column resizing working. -->
            <Style x:Key="ModernGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.GridHeaderBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
                <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Grid>
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="0,0,1,1"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ContentPresenter VerticalAlignment="Center" />
                                        <TextBlock x:Name="SortGlyph"
                                                   Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="9"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush.TextSecondary}" />
                                    </StackPanel>
                                </Border>
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       HorizontalAlignment="Right"
                                       Width="5"
                                       Cursor="SizeWE">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="SortDirection" Value="Ascending">
                                    <Setter TargetName="SortGlyph" Property="Text" Value="&#xE70E;" />
                                </Trigger>
                                <Trigger Property="SortDirection" Value="Descending">
                                    <Setter TargetName="SortGlyph" Property="Text" Value="&#xE70D;" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Row: hover and selected backgrounds only; the base background
                 comes from RowBackground/AlternatingRowBackground. -->
            <Style x:Key="ModernGridRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Cell: vertically centered content, no per-cell focus border.
                 Transparent background lets the row background show through. -->
            <Style x:Key="ModernGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="{StaticResource Radius.Sm}"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1">
        <DataGrid x:Name="InnerDataGrid"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  AutoGenerateColumns="{Binding AutoGenerateColumns, ElementName=RootControl}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                  RowBackground="{StaticResource Brush.Surface}"
                  AlternatingRowBackground="{StaticResource Brush.SurfaceAlt}"
                  RowHeight="{StaticResource Size.RowHeight}"
                  ColumnHeaderHeight="{StaticResource Size.GridHeaderHeight}"
                  ColumnHeaderStyle="{StaticResource ModernGridColumnHeaderStyle}"
                  RowStyle="{StaticResource ModernGridRowStyle}"
                  CellStyle="{StaticResource ModernGridCellStyle}"
                  FontSize="{StaticResource Font.Size.Body}"
                  Foreground="{StaticResource Brush.TextPrimary}"
                  EnableRowVirtualization="True"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  SelectionChanged="InnerDataGrid_SelectionChanged" />
    </Border>
</UserControl>
