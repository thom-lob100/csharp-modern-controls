<UserControl x:Class="Modern.Lab.Controls.Wpf.Data.ModernDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:data="clr-namespace:Modern.Lab.Controls.Wpf.Data"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="480" d:DesignHeight="240">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/ControlParts.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 컬럼 헤더: SemiBold 캡션, 은은한 구분선, 정렬 셰브런.
                 PART_RightHeaderGripper가 마우스로 컬럼 너비 조절이 계속 동작하게 한다. -->
            <Style x:Key="ModernGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.GridHeaderBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
                <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Grid>
                                <!-- 헤더-본문 경계(아래)는 Border, 컬럼 간 세로 구분은
                                     BorderSubtle — 명도 차로 구획을 분명히 한다. -->
                                <Border BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="0,0,0,1">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="0,0,1,0"
                                        Padding="{TemplateBinding Padding}">
                                    <!-- 오른쪽 끝은 [정렬 글리프][필터 깔때기] 순으로
                                         고정한다 — 깔때기(클릭 버튼)가 셀 맨 오른쪽이라
                                         클릭 위치가 항상 일정하고, 정렬 표시가 나타나도
                                         버튼이 밀리지 않는다. 깔때기는 컬럼의
                                         GridFilterAttach.Filterable(코드가 설정)로 켜진다. -->
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="SortGlyph"
                                                   Grid.Column="1"
                                                   Text=""
                                                   FontFamily="{StaticResource Font.Family.Icon}"
                                                   FontSize="{StaticResource Font.Size.IconSm}"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush.TextSecondary}" />
                                        <Button x:Name="FilterButton"
                                                Grid.Column="2"
                                                Margin="6,0,0,0"
                                                Cursor="Hand"
                                                Visibility="Collapsed"
                                                Click="OnHeaderFilterClick">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <ContentPresenter VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock x:Name="FilterGlyph"
                                                       Text="&#xE71C;"
                                                       FontFamily="{StaticResource Font.Family.Icon}"
                                                       FontSize="{StaticResource Font.Size.IconSm}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.TextSecondary}" />
                                        </Button>
                                    </Grid>
                                </Border>
                                </Border>
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       HorizontalAlignment="Right"
                                       Width="5"
                                       Cursor="SizeWE">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="SortDirection" Value="Ascending">
                                    <Setter TargetName="SortGlyph" Property="Text" Value="&#xE70E;" />
                                </Trigger>
                                <Trigger Property="SortDirection" Value="Descending">
                                    <Setter TargetName="SortGlyph" Property="Text" Value="&#xE70D;" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                                <!-- 컬럼 값 필터: Filterable 컬럼만 깔때기를 보이고,
                                     필터가 걸린 컬럼(IsActive)은 액센트색으로 칠한다. -->
                                <!-- FallbackValue: 채움용(filler) 헤더는 Column이 null이라
                                     바인딩이 실패한다 — 디버거 실행 시 오류 트레이스가
                                     쌓이지 않게 기본값 False로 조용히 처리한다. -->
                                <DataTrigger Binding="{Binding Column.(data:GridFilterAttach.Filterable), RelativeSource={RelativeSource Self}, FallbackValue=False}" Value="True">
                                    <Setter TargetName="FilterButton" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Column.(data:GridFilterAttach.IsActive), RelativeSource={RelativeSource Self}, FallbackValue=False}" Value="True">
                                    <Setter TargetName="FilterGlyph" Property="Foreground" Value="{StaticResource Brush.Accent}" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 행: hover/선택 배경만 지정; 기본 배경은 RowBackground에서 오고,
                 AlternatingRowColors 옵션이 켜지면 코드비하인드가
                 AlternatingRowBackground(교차색)를 추가로 설정한다. -->
            <Style x:Key="ModernGridRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 그리드 셀/헤더 체크박스는 공용 파츠(Parts.GridCheckBoxStyle)를 쓴다 —
                 GridColumnFactory가 이 키로 리소스를 조회한다. -->

            <!-- 셀: 내용 세로 중앙 정렬, 셀 단위 포커스 테두리 없음.
                 투명 배경이라 행 배경이 그대로 비쳐 보인다.
                 선택 배경은 행이 아니라 "셀"에서도 칠한다 — RowColorMemberPath가
                 행 Background를 로컬 값으로 설정하면(상태색 행) 행 스타일의
                 IsSelected 트리거가 로컬 값에 밀려 무시되므로, 셀이 위에서 덮어야
                 상태색 행에서도 선택 강조가 보인다. -->
            <Style x:Key="ModernGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="{StaticResource Radius.Sm}"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1">
        <DockPanel>
            <!-- 상태바: 그리드 하단에 붙는 얇은 요약 스트립.
                 왼쪽은 행 수(StatusCountFormat 형식), 오른쪽은 StatusText.
                 ShowStatusBar가 true일 때만 보인다. -->
            <Border x:Name="StatusBarStrip"
                    DockPanel.Dock="Bottom"
                    Visibility="Collapsed"
                    Background="{StaticResource Brush.SurfaceAlt}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="{StaticResource Pad.Field}">
                <DockPanel>
                    <TextBlock x:Name="StatusRightText"
                               DockPanel.Dock="Right"
                               FontSize="{StaticResource Font.Size.Label}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               VerticalAlignment="Center"
                               LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                    <TextBlock x:Name="StatusCountText"
                               FontSize="{StaticResource Font.Size.Label}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               VerticalAlignment="Center"
                               LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                </DockPanel>
            </Border>
            <Grid>
                <DataGrid x:Name="InnerDataGrid"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  AutoGenerateColumns="{Binding AutoGenerateColumns, ElementName=RootControl}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                  RowBackground="{StaticResource Brush.Surface}"
                  RowHeight="{StaticResource Size.RowHeight}"
                  ColumnHeaderHeight="{StaticResource Size.GridHeaderHeight}"
                  ColumnHeaderStyle="{StaticResource ModernGridColumnHeaderStyle}"
                  RowStyle="{StaticResource ModernGridRowStyle}"
                  CellStyle="{StaticResource ModernGridCellStyle}"
                  FontSize="{StaticResource Font.Size.Body}"
                  Foreground="{StaticResource Brush.TextPrimary}"
                  EnableRowVirtualization="True"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  SelectionChanged="InnerDataGrid_SelectionChanged" />

                <!-- 빈 상태 안내: 데이터가 0건일 때 데이터 영역 가운데에 흐린
                     글씨로 표시한다 (EmptyText, 빈 문자열이면 끔). 헤더는 그대로
                     보이도록 헤더 높이만큼 아래에서 가운데 정렬한다. -->
                <TextBlock x:Name="EmptyLabel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,34,0,0"
                           FontSize="{StaticResource Font.Size.Body}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"
                           LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
