<UserControl x:Class="Modern.Lab.Controls.Wpf.Data.ModernDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="480" d:DesignHeight="240">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 컬럼 헤더: SemiBold 캡션, 은은한 구분선, 정렬 셰브런.
                 PART_RightHeaderGripper가 마우스로 컬럼 너비 조절이 계속 동작하게 한다. -->
            <Style x:Key="ModernGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.GridHeaderBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
                <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Grid>
                                <!-- 헤더-본문 경계(아래)는 Border, 컬럼 간 세로 구분은
                                     BorderSubtle — 명도 차로 구획을 분명히 한다. -->
                                <Border BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="0,0,0,1">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="0,0,1,0"
                                        Padding="{TemplateBinding Padding}">
                                    <!-- 정렬 글리프는 텍스트 옆이 아니라 셀 오른쪽 끝에
                                         고정한다 — 컬럼 너비와 무관하게 위치가 일정해
                                         정렬 상태를 훑어보기 쉽다. -->
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="SortGlyph"
                                                   Grid.Column="1"
                                                   Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{StaticResource Font.Size.IconSm}"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush.TextSecondary}" />
                                    </Grid>
                                </Border>
                                </Border>
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       HorizontalAlignment="Right"
                                       Width="5"
                                       Cursor="SizeWE">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="SortDirection" Value="Ascending">
                                    <Setter TargetName="SortGlyph" Property="Text" Value="&#xE70E;" />
                                </Trigger>
                                <Trigger Property="SortDirection" Value="Descending">
                                    <Setter TargetName="SortGlyph" Property="Text" Value="&#xE70D;" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 행: hover/선택 배경만 지정; 기본 배경은
                 RowBackground/AlternatingRowBackground에서 온다. -->
            <Style x:Key="ModernGridRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 셀: 내용 세로 중앙 정렬, 셀 단위 포커스 테두리 없음.
                 투명 배경이라 행 배경이 그대로 비쳐 보인다.
                 선택 배경은 행이 아니라 "셀"에서도 칠한다 — RowColorMemberPath가
                 행 Background를 로컬 값으로 설정하면(상태색 행) 행 스타일의
                 IsSelected 트리거가 로컬 값에 밀려 무시되므로, 셀이 위에서 덮어야
                 상태색 행에서도 선택 강조가 보인다. -->
            <Style x:Key="ModernGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="{StaticResource Radius.Sm}"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1">
        <DockPanel>
            <!-- 상태바: 그리드 하단에 붙는 얇은 요약 스트립.
                 왼쪽은 행 수(StatusCountFormat 형식), 오른쪽은 StatusText.
                 ShowStatusBar가 true일 때만 보인다. -->
            <Border x:Name="StatusBarStrip"
                    DockPanel.Dock="Bottom"
                    Visibility="Collapsed"
                    Background="{StaticResource Brush.SurfaceAlt}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="{StaticResource Pad.Field}">
                <DockPanel>
                    <TextBlock x:Name="StatusRightText"
                               DockPanel.Dock="Right"
                               FontSize="{StaticResource Font.Size.Label}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusCountText"
                               FontSize="{StaticResource Font.Size.Label}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
            <DataGrid x:Name="InnerDataGrid"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  AutoGenerateColumns="{Binding AutoGenerateColumns, ElementName=RootControl}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                  RowBackground="{StaticResource Brush.Surface}"
                  AlternatingRowBackground="{StaticResource Brush.GridRowAlt}"
                  RowHeight="{StaticResource Size.RowHeight}"
                  ColumnHeaderHeight="{StaticResource Size.GridHeaderHeight}"
                  ColumnHeaderStyle="{StaticResource ModernGridColumnHeaderStyle}"
                  RowStyle="{StaticResource ModernGridRowStyle}"
                  CellStyle="{StaticResource ModernGridCellStyle}"
                  FontSize="{StaticResource Font.Size.Body}"
                  Foreground="{StaticResource Brush.TextPrimary}"
                  EnableRowVirtualization="True"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  SelectionChanged="InnerDataGrid_SelectionChanged" />
        </DockPanel>
    </Border>
</UserControl>
